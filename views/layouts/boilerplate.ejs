<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== "undefined" && title ? title + " | CortexConnect" : "CortexConnect" %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body class="bg-light">
    <%- include("../includes/navbar.ejs") %>

    <main class="container py-4">
        <% if (typeof flashMessages !== "undefined" && flashMessages) { %>
          <% const flashOrder = [
            { key: "danger", className: "alert-danger" },
            { key: "warning", className: "alert-warning" },
            { key: "success", className: "alert-success" },
            { key: "info", className: "alert-info" }
          ]; %>
          <% flashOrder.forEach((entry) => { %>
            <% (flashMessages[entry.key] || []).forEach((text) => { %>
              <div class="alert <%= entry.className %> alert-dismissible fade show" role="alert">
                <%= text %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              </div>
            <% }) %>
          <% }) %>
        <% } %>
        <%- body %>
    </main>

    <%- include("../includes/footer.ejs") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>
