<% layout("layouts/boilerplate") %>

<% const selectedCategory = typeof bedCategory !== "undefined" && bedCategory ? bedCategory : "icu"; %>
<% const categoryLabelMap = {
  normal: "Normal Ward",
  critical: "Critical Care",
  icu: "ICU"
}; %>
<% const selectedCategoryLabel = typeof bedCategoryLabel !== "undefined" && bedCategoryLabel
  ? bedCategoryLabel
  : (categoryLabelMap[selectedCategory] || "ICU"); %>
<% const pendingRows = Array.isArray(pendingRequests) ? pendingRequests : []; %>
<% const admissionRows = Array.isArray(recentAdmissions) ? recentAdmissions : []; %>
<% const summary = typeof bedSummary !== "undefined" && bedSummary ? bedSummary : null; %>
<% const pendingCountValue = typeof pendingCount !== "undefined" ? pendingCount : pendingRows.length; %>
<% const admissionCountValue = typeof matchingCount !== "undefined" ? matchingCount : admissionRows.length; %>
<% const totalBedsValue = typeof totalBeds !== "undefined" ? totalBeds : (summary ? summary.totalBeds : 0); %>

<div class="py-4 py-lg-5">
  <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
      <h1 class="h3 fw-bold mb-2">Bed Admissions</h1>
      <p class="text-muted mb-0">Doctor requests come in here first, and admin turns them into real admissions after checking capacity.</p>
    </div>
    <a href="/dashboard" class="btn btn-outline-primary">Dashboard</a>
  </div>

  <% if (typeof message !== "undefined" && message) { %>
    <div class="alert alert-info"><%= message %></div>
  <% } %>

  <div class="row g-4 mb-4">
    <div class="col-lg-4">
      <div class="card h-100">
        <div class="card-body p-4">
          <div class="text-muted small text-uppercase mb-2">Total Beds</div>
          <div class="display-6 fw-bold mb-2"><%= totalBedsValue %></div>
          <div class="text-muted small"><%= selectedCategoryLabel %> snapshot</div>
        </div>
      </div>
    </div>

    <div class="col-lg-8">
      <div class="card h-100">
        <div class="card-body p-4">
          <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <h2 class="h5 mb-0">Ward Filter</h2>
            <span class="badge text-bg-light border"><%= admissionCountValue %> matching admissions</span>
          </div>

          <form action="/bed-admissions" method="GET" class="row g-3">
            <div class="col-md-4">
              <label class="form-label">Category</label>
              <select name="bed_category" class="form-select">
                <option value="icu" <%= selectedCategory === "icu" ? "selected" : "" %>>ICU</option>
                <option value="critical" <%= selectedCategory === "critical" ? "selected" : "" %>>Critical Care</option>
                <option value="normal" <%= selectedCategory === "normal" ? "selected" : "" %>>Normal Ward</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Search Patient</label>
              <input
                type="search"
                name="search"
                class="form-control"
                value="<%= typeof search !== 'undefined' ? search : '' %>"
                placeholder="Search by patient name"
              >
            </div>
            <div class="col-md-2 d-flex align-items-end">
              <button type="submit" class="btn btn-primary w-100">Load</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Occupied</div>
          <div class="h3 mb-0"><%= summary ? summary.occupiedBeds : 0 %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Free Beds</div>
          <div class="h3 mb-0"><%= summary ? summary.freeBeds : 0 %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Occupancy</div>
          <div class="h3 mb-0"><%= summary ? summary.occupancyPct : 0 %>%</div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Pending Requests</div>
          <div class="h3 mb-0"><%= pendingCountValue %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body p-4">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
          <h2 class="h5 mb-1">Pending Bed Requests</h2>
          <p class="text-muted small mb-0">Approve or reject requests before they become admissions.</p>
        </div>
        <span class="badge text-bg-light border"><%= pendingRows.length %> queued</span>
      </div>

      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Patient</th>
              <th>Doctor</th>
              <th>Category</th>
              <th>Urgency</th>
              <th>Appointment</th>
              <th>Notes</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (pendingRows.length === 0) { %>
              <tr>
                <td colspan="7" class="text-center py-4 text-muted">No pending requests for <%= selectedCategoryLabel %>.</td>
              </tr>
            <% } else { %>
              <% pendingRows.forEach((record) => { %>
                <% const appointment = record.appointment_id && record.appointment_id.full_name ? record.appointment_id : null; %>
                <% const patientUser = appointment && appointment.user_id && appointment.user_id.first_name ? appointment.user_id : null; %>
                <% const patientName = patientUser ? patientUser.first_name + " " + patientUser.last_name : record.patient_name || appointment?.full_name || "-"; %>
                <% const doctorUser = record.doctor_id && record.doctor_id.name ? record.doctor_id : null; %>
                <% const doctorName = doctorUser ? doctorUser.name : record.doctor_name || "-" %>
                <% const approveAction = "/bed-admissions/requests/" + record._id + "/approve?bed_category=" + selectedCategory + "&search=" + encodeURIComponent(typeof search !== 'undefined' ? search : ''); %>
                <% const rejectAction = "/bed-admissions/requests/" + record._id + "/reject?bed_category=" + selectedCategory + "&search=" + encodeURIComponent(typeof search !== 'undefined' ? search : ''); %>
                <tr>
                  <td>
                    <div class="fw-semibold"><%= patientName %></div>
                    <div class="text-muted small"><%= record.patient_email || appointment?.email || "-" %></div>
                  </td>
                  <td><%= doctorName %></td>
                  <td><%= record.bed_category || "-" %></td>
                  <td><span class="badge text-bg-<%= record.urgency_level === 'high' ? 'danger' : record.urgency_level === 'medium' ? 'warning' : 'success' %>"><%= record.urgency_level || "-" %></span></td>
                  <td>
                    <div><%= appointment ? appointment.appointment_date : "-" %></div>
                    <div class="text-muted small"><%= appointment ? appointment.time_slot : "-" %></div>
                  </td>
                  <td><%= record.notes || appointment?.symptoms || "-" %></td>
                  <td>
                    <div class="d-flex flex-wrap gap-2">
                      <form action="<%= approveAction %>" method="POST">
                        <button type="submit" class="btn btn-sm btn-success">Approve</button>
                      </form>
                      <form action="<%= rejectAction %>" method="POST">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body p-4">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
          <h2 class="h5 mb-1"><%= selectedCategoryLabel %> Admissions</h2>
          <p class="text-muted small mb-0">These are the patients already admitted to the selected ward.</p>
        </div>
        <span class="badge text-bg-light border"><%= admissionRows.length %> records</span>
      </div>

      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Patient</th>
              <th>Bed</th>
              <th>Capacity</th>
              <th>Status</th>
              <th>Date</th>
              <th>Source</th>
            </tr>
          </thead>
          <tbody>
            <% if (admissionRows.length === 0) { %>
              <tr>
                <td colspan="6" class="text-center py-4 text-muted">No <%= selectedCategoryLabel %> admissions found.</td>
              </tr>
            <% } else { %>
              <% admissionRows.forEach((record) => { %>
                <% const patientUser = record.patient_user_id && record.patient_user_id.first_name ? record.patient_user_id : null; %>
                <% const patientName = patientUser ? patientUser.first_name + " " + patientUser.last_name : record.patient_name || "-"; %>
                <% const statusClass = record.status === "admitted"
                  ? "success"
                  : record.status === "waiting"
                    ? "warning"
                    : record.status === "transferred"
                      ? "info"
                      : "secondary"; %>
                <tr>
                  <td>
                    <div class="fw-semibold"><%= patientName %></div>
                    <div class="text-muted small"><%= record.patient_email || "-" %></div>
                  </td>
                  <td>
                    <div><%= record.bed_assigned || "Not assigned" %></div>
                    <div class="text-muted small text-uppercase"><%= record.bed_category %></div>
                  </td>
                  <td>
                    <div>Total: <%= record.total_beds %></div>
                    <div class="text-muted small">Occupied: <%= record.occupied_beds %> | Free: <%= Math.max(record.total_beds - record.occupied_beds, 0) %></div>
                  </td>
                  <td><span class="badge text-bg-<%= statusClass %> text-uppercase"><%= record.status %></span></td>
                  <td><%= record.admission_date %></td>
                  <td>
                    <% if (record.source_request_id) { %>
                      From doctor request
                    <% } else { %>
                      Manual entry
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
