<% layout("layouts/boilerplate") %>

<div class="py-4 py-lg-5">
  <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
      <h1 class="h3 fw-bold mb-2">Bed Admissions</h1>
      <p class="text-muted mb-0">Track ICU, critical, and normal bed pressure from the admin side.</p>
    </div>
    <a href="/dashboard" class="btn btn-outline-primary">Dashboard</a>
  </div>

  <% if (message) { %>
    <div class="alert alert-info"><%= message %></div>
  <% } %>

  <% if (bedAlert) { %>
    <div class="alert alert-<%= bedAlertClass || 'info' %>"><%= bedAlert %></div>
  <% } %>

  <div class="row g-4 mb-4">
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Total Beds</div>
          <div class="h3 mb-0"><%= bedSummary ? bedSummary.totalBeds : 0 %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Occupied</div>
          <div class="h3 mb-0"><%= bedSummary ? bedSummary.occupiedBeds : 0 %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Free Beds</div>
          <div class="h3 mb-0"><%= bedSummary ? bedSummary.freeBeds : 0 %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Occupancy</div>
          <div class="h3 mb-0"><%= bedSummary ? bedSummary.occupancyPct : 0 %>%</div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4 mb-4">
    <div class="col-lg-7">
      <div class="card h-100">
        <div class="card-body p-4">
          <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <h2 class="h5 mb-0">Current Pressure</h2>
            <span class="badge text-bg-light border">Prediction window: 3 days</span>
          </div>

          <div class="mb-3">
            <div class="d-flex justify-content-between small text-muted mb-1">
              <span>Occupancy</span>
              <span><%= bedSummary ? bedSummary.occupancyPct : 0 %>%</span>
            </div>
            <div class="progress" style="height: 12px;">
              <% const bedOccupancyBarPct = Math.min(bedSummary ? bedSummary.occupancyPct : 0, 100); %>
              <div
                class="progress-bar <%= bedSummary && bedSummary.occupancyPct >= 90 ? 'bg-danger' : bedSummary && bedSummary.occupancyPct >= 80 ? 'bg-warning' : 'bg-success' %>"
                role="progressbar"
                style="width: <%= bedOccupancyBarPct %>%"
                aria-valuenow="<%= bedSummary ? bedSummary.occupancyPct : 0 %>"
                aria-valuemin="0"
                aria-valuemax="100"
              ></div>
            </div>
          </div>

          <div class="row g-3">
            <div class="col-md-4">
              <div class="border rounded-3 p-3 h-100">
                <div class="text-muted small">Expected Discharges</div>
                <div class="h4 mb-0"><%= bedSummary ? bedSummary.expectedDischarges : 0 %></div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="border rounded-3 p-3 h-100">
                <div class="text-muted small">Projected Occupied</div>
                <div class="h4 mb-0"><%= bedProjection ? bedProjection.projected : (bedSummary ? bedSummary.occupiedBeds : 0) %></div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="border rounded-3 p-3 h-100">
                <div class="text-muted small">Projected Free</div>
                <div class="h4 mb-0"><%= bedSummary ? Math.max(bedSummary.totalBeds - (bedProjection ? bedProjection.projected : bedSummary.occupiedBeds), 0) : 0 %></div>
              </div>
            </div>
          </div>

          <hr class="my-4">

          <h3 class="h6 text-uppercase text-muted mb-3">Recent Category Demand</h3>
          <% const maxBedDemand = Math.max((bedSummary && bedSummary.normalBeds) || 0, (bedSummary && bedSummary.criticalBeds) || 0, (bedSummary && bedSummary.icuBeds) || 0, 1); %>
          <% const normalBedPct = Math.round((((bedSummary ? bedSummary.normalBeds : 0)) / maxBedDemand) * 100); %>
          <% const criticalBedPct = Math.round((((bedSummary ? bedSummary.criticalBeds : 0)) / maxBedDemand) * 100); %>
          <% const icuBedPct = Math.round((((bedSummary ? bedSummary.icuBeds : 0)) / maxBedDemand) * 100); %>
          <div class="mb-3">
            <div class="d-flex justify-content-between small mb-1">
              <span>Normal</span>
              <span><%= bedSummary ? bedSummary.normalBeds : 0 %></span>
            </div>
            <div class="progress" style="height: 10px;">
              <div class="progress-bar bg-primary" style="width: <%= normalBedPct %>%"></div>
            </div>
          </div>
          <div class="mb-3">
            <div class="d-flex justify-content-between small mb-1">
              <span>Critical</span>
              <span><%= bedSummary ? bedSummary.criticalBeds : 0 %></span>
            </div>
            <div class="progress" style="height: 10px;">
              <div class="progress-bar bg-warning" style="width: <%= criticalBedPct %>%"></div>
            </div>
          </div>
          <div>
            <div class="d-flex justify-content-between small mb-1">
              <span>ICU</span>
              <span><%= bedSummary ? bedSummary.icuBeds : 0 %></span>
            </div>
            <div class="progress" style="height: 10px;">
              <div class="progress-bar bg-danger" style="width: <%= icuBedPct %>%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="card h-100">
        <div class="card-body p-4">
          <h2 class="h5 mb-3">Patient Lookup</h2>
          <form action="/bed-admissions" method="GET" class="row g-3">
            <div class="col-12">
              <label class="form-label">Choose Patient</label>
              <select name="patient_user_id" class="form-select" onchange="this.form.submit()">
                <option value="">Select a patient</option>
                <% patients.forEach((patient) => { %>
                  <option value="<%= patient._id %>" <%= selectedPatient && String(selectedPatient._id) === String(patient._id) ? 'selected' : '' %>><%= patient.first_name %> <%= patient.last_name %> | <%= patient.email %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-12">
              <button type="submit" class="btn btn-outline-primary w-100">Load Patient</button>
            </div>
          </form>

          <% if (selectedPatient) { %>
            <hr class="my-4">
            <div class="border rounded-3 p-3 bg-light">
              <div class="text-uppercase text-muted small mb-1">Selected Patient</div>
              <h3 class="h5 mb-1"><%= selectedPatient.first_name %> <%= selectedPatient.last_name %></h3>
              <div class="text-muted small"><%= selectedPatient.email %></div>
              <div class="text-muted small">Role: <%= selectedPatient.role %></div>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body p-4">
      <h2 class="h5 mb-3">Record Bed Admission Snapshot</h2>
      <form action="/bed-admissions" method="POST" class="row g-3">
        <input type="hidden" name="patient_user_id" value="<%= formData.patient_user_id || '' %>">

        <div class="col-md-4">
          <label class="form-label">Patient Name</label>
          <input type="text" name="patient_name" class="form-control" value="<%= formData.patient_name || '' %>" readonly>
        </div>
        <div class="col-md-4">
          <label class="form-label">Patient Email</label>
          <input type="email" name="patient_email" class="form-control" value="<%= formData.patient_email || '' %>" readonly>
        </div>
        <div class="col-md-4">
          <label class="form-label">Patient Phone</label>
          <input type="tel" name="patient_phone" class="form-control" value="<%= formData.patient_phone || '' %>" required pattern="[0-9]{10}">
        </div>

        <div class="col-md-4">
          <label class="form-label">Bed Category</label>
          <select name="bed_category" class="form-select" required>
            <option value="normal" <%= (formData.bed_category || 'normal') === 'normal' ? 'selected' : '' %>>Normal</option>
            <option value="critical" <%= (formData.bed_category || '') === 'critical' ? 'selected' : '' %>>Critical</option>
            <option value="icu" <%= (formData.bed_category || '') === 'icu' ? 'selected' : '' %>>ICU</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Bed Required</label>
          <input type="number" name="bed_required" class="form-control" min="1" max="50" value="<%= formData.bed_required || 1 %>" required>
        </div>
        <div class="col-md-4">
          <label class="form-label">Bed Assigned</label>
          <input type="text" name="bed_assigned" class="form-control" value="<%= formData.bed_assigned || '' %>" placeholder="Optional room / bed number">
        </div>

        <div class="col-md-3">
          <label class="form-label">Total Beds</label>
          <input type="number" name="total_beds" class="form-control" min="0" value="<%= formData.total_beds || 50 %>" required>
        </div>
        <div class="col-md-3">
          <label class="form-label">Occupied Beds</label>
          <input type="number" name="occupied_beds" class="form-control" min="0" value="<%= formData.occupied_beds || 0 %>" required>
        </div>
        <div class="col-md-3">
          <label class="form-label">Admissions Today</label>
          <input type="number" name="admissions_today" class="form-control" min="0" value="<%= formData.admissions_today || 1 %>" required>
        </div>
        <div class="col-md-3">
          <label class="form-label">Discharges Today</label>
          <input type="number" name="discharges_today" class="form-control" min="0" value="<%= formData.discharges_today || 0 %>" required>
        </div>

        <div class="col-md-4">
          <label class="form-label">Expected Discharges Next Days</label>
          <input type="number" name="expected_discharges_next_days" class="form-control" min="0" value="<%= formData.expected_discharges_next_days || 0 %>" required>
        </div>
        <div class="col-md-4">
          <label class="form-label">Admission Date</label>
          <input type="date" name="admission_date" class="form-control" value="<%= formData.admission_date || '' %>" required>
        </div>
        <div class="col-md-4">
          <label class="form-label">Discharge Date</label>
          <input type="date" name="discharge_date" class="form-control" value="<%= formData.discharge_date || '' %>">
        </div>

        <div class="col-md-3">
          <label class="form-label">Status</label>
          <select name="status" class="form-select" required>
            <option value="admitted" <%= (formData.status || 'admitted') === 'admitted' ? 'selected' : '' %>>Admitted</option>
            <option value="discharged" <%= (formData.status || '') === 'discharged' ? 'selected' : '' %>>Discharged</option>
            <option value="transferred" <%= (formData.status || '') === 'transferred' ? 'selected' : '' %>>Transferred</option>
            <option value="waiting" <%= (formData.status || '') === 'waiting' ? 'selected' : '' %>>Waiting</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">Urgency</label>
          <select name="urgency_level" class="form-select" required>
            <option value="low" <%= (formData.urgency_level || '') === 'low' ? 'selected' : '' %>>Low</option>
            <option value="medium" <%= (formData.urgency_level || 'medium') === 'medium' ? 'selected' : '' %>>Medium</option>
            <option value="high" <%= (formData.urgency_level || '') === 'high' ? 'selected' : '' %>>High</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">Department</label>
          <input type="text" name="department" class="form-control" value="<%= formData.department || '' %>" placeholder="ICU / Ward / ER">
        </div>
        <div class="col-md-3">
          <label class="form-label">Notes</label>
          <input type="text" name="notes" class="form-control" value="<%= formData.notes || '' %>" placeholder="Optional note">
        </div>

        <div class="col-12">
          <button type="submit" class="btn btn-primary">Save Bed Snapshot</button>
        </div>
      </form>
    </div>
  </div>

  <div class="card">
    <div class="card-body p-4">
      <h2 class="h5 mb-3">Recent Bed Admissions</h2>
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Patient</th>
              <th>Category</th>
              <th>Capacity</th>
              <th>Snapshot</th>
              <th>Status</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% if (!recentAdmissions || recentAdmissions.length === 0) { %>
              <tr>
                <td colspan="6" class="text-center py-4 text-muted">No bed admissions recorded yet.</td>
              </tr>
            <% } else { %>
              <% recentAdmissions.forEach((record) => { %>
                <tr>
                  <td>
                    <div class="fw-semibold"><%= record.patient_user_id && record.patient_user_id.first_name ? record.patient_user_id.first_name + " " + record.patient_user_id.last_name : record.patient_name %></div>
                    <div class="text-muted small"><%= record.patient_email %></div>
                  </td>
                  <td>
                    <span class="badge text-bg-<%= record.bed_category === 'icu' ? 'danger' : record.bed_category === 'critical' ? 'warning' : 'primary' %> text-uppercase">
                      <%= record.bed_category %>
                    </span>
                  </td>
                  <td>
                    <div>Total: <%= record.total_beds %></div>
                    <div class="text-muted small">Occupied: <%= record.occupied_beds %> | Free: <%= Math.max(record.total_beds - record.occupied_beds, 0) %></div>
                  </td>
                  <td>
                    <div>Req: <%= record.bed_required %></div>
                    <div class="text-muted small">Adm: <%= record.admissions_today %> | Dis: <%= record.discharges_today %></div>
                  </td>
                  <td><span class="badge text-bg-secondary text-uppercase"><%= record.status %></span></td>
                  <td><%= record.admission_date %></td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
