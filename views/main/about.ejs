<% layout("layouts/boilerplate") %>

<div class="py-4">
  <div class="card">
    <div class="card-body p-4 p-md-5">
      <h1 class="h3 mb-3">About CortexConnect</h1>
      <p class="mb-3">
        CortexConnect is a simple Express and EJS application backed by MongoDB for patient and hospital operations.
      </p>
      <p class="mb-0 text-muted">
        Users are saved in the users collection, appointment details are saved in the appointment_details collection, doctor bed requests are kept in bed_requests, and admissions stay in bed_admissions.
      </p>
    </div>
  </div>
</div>
