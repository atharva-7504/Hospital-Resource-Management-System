<% layout("layouts/boilerplate") %>

<% const rosterRows = Array.isArray(filteredRoster) ? filteredRoster : []; %>
<% const doctorOptions = Array.isArray(doctorRows) ? doctorRows : []; %>
<% const summary = typeof staffSummary !== "undefined" && staffSummary ? staffSummary : null; %>
<% const selectedDoctorValue = typeof selectedDoctorRow !== "undefined" && selectedDoctorRow ? selectedDoctorRow : null; %>
<% const formValues = typeof formData !== "undefined" && formData ? formData : {}; %>

<div class="py-4 py-lg-5">
  <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
      <h1 class="h3 fw-bold mb-2">Staff Roster</h1>
      <p class="text-muted mb-0">Active and inactive doctors live here, so the appointment list and doctor dashboard stay in sync.</p>
    </div>
    <a href="/dashboard" class="btn btn-outline-primary">Dashboard</a>
  </div>

  <% if (typeof message !== "undefined" && message) { %>
    <div class="alert alert-info"><%= message %></div>
  <% } %>
  <% if (typeof staffAlert !== "undefined" && staffAlert) { %>
    <div class="alert alert-<%= staffAlertClass || 'info' %>"><%= staffAlert %></div>
  <% } %>

  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Total Staff</div>
          <div class="h3 mb-0"><%= summary ? summary.totalStaff : 0 %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Active Staff</div>
          <div class="h3 mb-0"><%= summary ? summary.activeStaff : 0 %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Inactive Staff</div>
          <div class="h3 mb-0"><%= summary ? summary.leftStaff : 0 %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100">
        <div class="card-body">
          <div class="text-muted small">Doctor Accounts</div>
          <div class="h3 mb-0"><%= doctorOptions.length %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4 mb-4">
    <div class="col-lg-8">
      <div class="card h-100">
        <div class="card-body p-4">
          <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div>
              <h2 class="h5 mb-1">Update Doctor Status</h2>
              <p class="text-muted small mb-0">Switch a doctor on or off, then keep their working hours and department aligned.</p>
            </div>
            <span class="badge text-bg-light border"><%= doctorOptions.length %> editable</span>
          </div>

          <% if (doctorOptions.length === 0) { %>
            <div class="alert alert-warning mb-0">No doctor accounts found yet.</div>
          <% } else { %>
            <form action="/staff-records" method="POST" class="row g-3" data-staff-roster-form>
              <input type="hidden" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>">
              <div class="col-md-12">
                <label class="form-label">Doctor Account</label>
                <select name="doctor_id" class="form-select" required data-staff-doctor-select>
                  <option value="">Choose a doctor</option>
                  <% doctorOptions.forEach((doctor) => { %>
                    <option
                      value="<%= doctor.doctor_id %>"
                      <%= String(formValues.doctor_id || (selectedDoctorValue ? selectedDoctorValue.doctor_id : "")) === String(doctor.doctor_id) ? "selected" : "" %>
                      data-staff-name="<%= doctor.staff_name %>"
                      data-staff-role="<%= doctor.role_label %>"
                      data-specialization="<%= doctor.specialization_label %>"
                      data-status="<%= doctor.status %>"
                      data-department="<%= doctor.department %>"
                      data-start-time="<%= doctor.hospital_start_time %>"
                      data-end-time="<%= doctor.hospital_end_time %>"
                      data-days="<%= doctor.availability_days.join(', ') %>"
                      data-bio="<%= doctor.doctor_bio || '' %>"
                    >
                      <%= doctor.staff_name %> | <%= doctor.department %> | <%= doctor.status_label %>
                    </option>
                  <% }) %>
                </select>
              </div>

              <div class="col-md-4">
                <label class="form-label">Status</label>
                <select name="active" class="form-select" required>
                  <option value="true" <%= String(formValues.active || (selectedDoctorValue && selectedDoctorValue.active ? "true" : "false")) === "true" ? "selected" : "" %>>Active</option>
                  <option value="false" <%= String(formValues.active || (selectedDoctorValue && selectedDoctorValue.active ? "true" : "false")) === "false" ? "selected" : "" %>>Inactive</option>
                </select>
              </div>

              <div class="col-md-8">
                <label class="form-label">Department</label>
                <input type="text" name="department" class="form-control" value="<%= formValues.department || (selectedDoctorValue ? selectedDoctorValue.department : '') %>" placeholder="Cardiology / ICU / Orthopedic" required>
              </div>

              <div class="col-md-4">
                <label class="form-label">Start Time</label>
                <input type="time" name="hospital_start_time" class="form-control" value="<%= formValues.hospital_start_time || (selectedDoctorValue ? selectedDoctorValue.hospital_start_time : '') %>" required>
              </div>

              <div class="col-md-4">
                <label class="form-label">End Time</label>
                <input type="time" name="hospital_end_time" class="form-control" value="<%= formValues.hospital_end_time || (selectedDoctorValue ? selectedDoctorValue.hospital_end_time : '') %>" required>
              </div>

              <div class="col-md-4">
                <label class="form-label">Availability Days</label>
                <select name="availability_days" class="form-select" multiple size="4" required>
                  <% ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"].forEach((day) => { %>
                    <option value="<%= day %>" <%= (formValues.availability_days || (selectedDoctorValue ? selectedDoctorValue.availability_days : [])).includes(day) ? "selected" : "" %>><%= day %></option>
                  <% }) %>
                </select>
              </div>

              <div class="col-12">
                <label class="form-label">Doctor Bio</label>
                <textarea name="doctor_bio" class="form-control" rows="4" placeholder="Optional short bio"><%= formValues.doctor_bio || (selectedDoctorValue ? selectedDoctorValue.doctor_bio : "") %></textarea>
              </div>

              <div class="col-12 d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">Save Status</button>
                <a href="/staff-records" class="btn btn-outline-secondary">Reset View</a>
              </div>
            </form>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
            <h2 class="h5 mb-0">Selected Doctor</h2>
            <span class="badge text-bg-light border" data-staff-status-badge><%= selectedDoctorValue ? selectedDoctorValue.status_label : "Waiting" %></span>
          </div>

          <% if (selectedDoctorValue) { %>
            <div class="border rounded-3 p-3 bg-light mb-3">
              <div class="fw-semibold mb-1" data-staff-name-preview><%= selectedDoctorValue.staff_name %></div>
              <div class="text-muted small" data-staff-role-preview><%= selectedDoctorValue.role_label %></div>
              <div class="text-muted small" data-staff-department-preview><%= selectedDoctorValue.department %></div>
            </div>

            <dl class="row small mb-0">
              <dt class="col-5 text-muted fw-normal">Specialization</dt>
              <dd class="col-7" data-staff-specialization-preview><%= selectedDoctorValue.specialization_label %></dd>

              <dt class="col-5 text-muted fw-normal">Hours</dt>
              <dd class="col-7" data-staff-hours-preview><%= selectedDoctorValue.hours_label %></dd>

              <dt class="col-5 text-muted fw-normal">Days</dt>
              <dd class="col-7" data-staff-days-preview><%= selectedDoctorValue.availability_label %></dd>

              <dt class="col-5 text-muted fw-normal">Bio</dt>
              <dd class="col-7" data-staff-bio-preview><%= selectedDoctorValue.doctor_bio || "-" %></dd>
            </dl>
          <% } else { %>
            <div class="alert alert-light border mb-0">Choose a doctor to see the current roster details here.</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-body p-4">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
          <h2 class="h5 mb-1">Search Roster</h2>
          <p class="text-muted small mb-0">Search by doctor name, department, role, or status.</p>
        </div>
        <span class="badge text-bg-light border"><%= matchingCount || rosterRows.length %> matching</span>
      </div>

      <form action="/staff-records" method="GET" class="row g-3 mb-4">
        <div class="col-md-8">
          <label class="form-label">Search by Name</label>
          <input
            type="search"
            name="search"
            class="form-control"
            value="<%= typeof search !== 'undefined' ? search : '' %>"
            placeholder="Type a staff name"
          >
        </div>
        <div class="col-md-4 d-flex align-items-end">
          <button type="submit" class="btn btn-outline-primary w-100">Search</button>
        </div>
      </form>

      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Staff</th>
              <th>Role</th>
              <th>Department</th>
              <th>Status</th>
              <th>Hours</th>
              <th>Availability</th>
              <th>Updated</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (rosterRows.length === 0) { %>
              <tr>
                <td colspan="8" class="text-center py-4 text-muted">No matching staff found.</td>
              </tr>
            <% } else { %>
              <% rosterRows.forEach((record) => { %>
                <% const loadDoctorId = record.doctor_id ? String(record.doctor_id) : ""; %>
                <tr>
                  <td>
                    <div class="fw-semibold"><%= record.staff_name %></div>
                    <div class="text-muted small"><%= record.specialization_label %></div>
                  </td>
                  <td><%= record.role_label %></td>
                  <td><%= record.department %></td>
                  <td><span class="badge text-bg-<%= record.active ? 'success' : 'secondary' %> text-uppercase"><%= record.status_label %></span></td>
                  <td><%= record.hours_label %></td>
                  <td><%= record.availability_label %></td>
                  <td><%= record.latestDate ? new Date(record.latestDate).toLocaleString() : "-" %></td>
                  <td class="text-end">
                    <% if (loadDoctorId) { %>
                      <a href="/staff-records?doctor_id=<%= loadDoctorId %>&search=<%= encodeURIComponent(typeof search !== 'undefined' ? search : '') %>" class="btn btn-outline-primary btn-sm">Load</a>
                    <% } else { %>
                      <span class="text-muted small">Locked</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script src="/js/staffRoster.js"></script>
