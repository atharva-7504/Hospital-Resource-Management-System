<nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold" href="/">CortexConnect</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNav">
      <div class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
        <% if (currentUser) { %>
          <% if (currentUser.role === "admin" || currentUser.role === "doctor") { %>
            <a class="nav-link" href="/dashboard">Dashboard</a>
            <% if (currentUser.role === "admin") { %>
              <a class="nav-link" href="/predict">Predict</a>
            <% } %>
            <a class="nav-link" href="/check-appointments">Check Appointments</a>
            <% if (currentUser.role === "admin") { %>
              <a class="nav-link" href="/bed-admissions">Bed Admissions</a>
              <a class="nav-link" href="/staff-records">Staff Records</a>
            <% } %>
          <% } else { %>
            <a class="nav-link" href="/appointment">Appointment</a>
            <a class="nav-link" href="/check-status">Check Status</a>
          <% } %>

          <div class="dropdown">
            <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
              <%= currentUser.first_name || currentUser.full_name || currentUser.username || "Profile" %>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <h6 class="dropdown-header">
                  <%= currentUser.first_name && currentUser.last_name ? currentUser.first_name + " " + currentUser.last_name : (currentUser.full_name || currentUser.username) %>
                </h6>
              </li>
              <li><span class="dropdown-item-text text-muted small"><%= currentUser.role === "admin" ? "Admin" : currentUser.role === "doctor" ? "Doctor" : "Patient" %></span></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/profile">Profile</a></li>
              <% if (currentUser.role === "admin" || currentUser.role === "doctor") { %>
                <li><a class="dropdown-item" href="/dashboard">Dashboard</a></li>
                <li><a class="dropdown-item" href="/check-appointments">Check Appointments</a></li>
                <% if (currentUser.role === "admin") { %>
                  <li><a class="dropdown-item" href="/predict">Predict</a></li>
                  <li><a class="dropdown-item" href="/bed-admissions">Bed Admissions</a></li>
                  <li><a class="dropdown-item" href="/staff-records">Staff Records</a></li>
                <% } %>
              <% } else { %>
                <li><a class="dropdown-item" href="/appointment">Appointment</a></li>
                <li><a class="dropdown-item" href="/check-status">Check Status</a></li>
              <% } %>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
            </ul>
          </div>
        <% } else { %>
          <a class="nav-link" href="/">Home</a>
          <a class="nav-link" href="/features">Features</a>
          <a class="nav-link" href="/about">About Us</a>
          <a class="nav-link" href="/login">Login</a>
          <a class="nav-link" href="/signup">Signup</a>
        <% } %>
      </div>
    </div>
  </div>
</nav>
