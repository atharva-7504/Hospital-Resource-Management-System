<% layout("layouts/boilerplate") %>

<div class="py-4 py-lg-5">
  <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
    <div>
      <h1 class="h3 fw-bold mb-2">Profile</h1>
      <p class="text-muted mb-0">Your account details and recent activity.</p>
    </div>
    <% if (profile.role === "admin" || profile.role === "doctor") { %>
      <a href="/dashboard" class="btn btn-outline-primary">Dashboard</a>
    <% } else { %>
      <a href="/appointment" class="btn btn-outline-primary">Appointment</a>
    <% } %>
  </div>

  <div class="row g-4">
    <div class="col-lg-5">
      <div class="card h-100">
        <div class="card-body p-4">
          <h2 class="h5 mb-3">Account Details</h2>
          <dl class="row mb-0">
            <dt class="col-5 text-muted fw-normal">Full Name</dt>
            <dd class="col-7"><%= profile.fullName || "-" %></dd>

            <dt class="col-5 text-muted fw-normal">First Name</dt>
            <dd class="col-7"><%= profile.firstName || "-" %></dd>

            <dt class="col-5 text-muted fw-normal">Last Name</dt>
            <dd class="col-7"><%= profile.lastName || "-" %></dd>

            <dt class="col-5 text-muted fw-normal">Username</dt>
            <dd class="col-7"><%= profile.username || "-" %></dd>

            <dt class="col-5 text-muted fw-normal">Email</dt>
            <dd class="col-7"><%= profile.email || "-" %></dd>

            <dt class="col-5 text-muted fw-normal">Role</dt>
            <dd class="col-7"><%= profile.roleLabel || "-" %></dd>

            <dt class="col-5 text-muted fw-normal">Provider</dt>
            <dd class="col-7"><%= profile.provider || "-" %></dd>

            <dt class="col-5 text-muted fw-normal">User ID</dt>
            <dd class="col-7 text-break"><%= profile.id || "-" %></dd>

            <dt class="col-5 text-muted fw-normal">Created</dt>
            <dd class="col-7"><%= profile.createdAt || "-" %></dd>
          </dl>
        </div>
      </div>
    </div>

    <div class="col-lg-7">
      <% if (profile.role === "doctor" && doctorProfile) { %>
        <div class="card mb-4">
          <div class="card-body p-4">
            <h2 class="h5 mb-3">Doctor Profile</h2>
            <div class="row g-3">
              <div class="col-md-4">
                <div class="text-muted small">Specialization</div>
                <div class="fw-semibold"><%= doctorProfile.specialization === "general_physician" ? "General Physician" : doctorProfile.specialization === "orthopedic" ? "Orthopedic" : "Cardiology" %></div>
              </div>
              <div class="col-md-4">
                <div class="text-muted small">Department</div>
                <div class="fw-semibold"><%= doctorProfile.department || "-" %></div>
              </div>
              <div class="col-md-4">
                <div class="text-muted small">Hospital Hours</div>
                <div class="fw-semibold"><%= doctorProfile.hospital_start_time || "-" %> to <%= doctorProfile.hospital_end_time || "-" %></div>
              </div>
              <div class="col-12">
                <div class="text-muted small">Availability Days</div>
                <div class="fw-semibold"><%= (doctorProfile.availability_days || []).join(", ") || "-" %></div>
              </div>
              <% if (doctorProfile.doctor_bio) { %>
                <div class="col-12">
                  <div class="text-muted small">Profile Notes</div>
                  <div><%= doctorProfile.doctor_bio %></div>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      <% } %>

      <div class="card mb-4">
        <div class="card-body p-4">
          <h2 class="h5 mb-3">Role Overview</h2>
          <% if (profile.role === "admin") { %>
            <p class="mb-0 text-muted">Admins can review all appointments, approve or reject bookings, and open the dashboard.</p>
          <% } else if (profile.role === "doctor") { %>
            <p class="mb-0 text-muted">Doctors can review approved appointments, view their schedule, and manage patient follow-ups.</p>
          <% } else { %>
            <p class="mb-0 text-muted">Patients can book appointments, track status, and manage their booking details.</p>
          <% } %>
        </div>
      </div>

      <div class="card">
        <div class="card-body p-4">
          <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
            <h2 class="h5 mb-0">Recent Appointments</h2>
            <span class="badge text-bg-light border"><%= (recentAppointments || []).length %> records</span>
          </div>

          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <% if (profile.role === "doctor") { %>
                    <th>Patient</th>
                    <th>Email</th>
                    <th>Date</th>
                  <% } else if (profile.role === "admin") { %>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Date</th>
                  <% } else { %>
                    <th>Date</th>
                    <th>Doctor</th>
                    <th>Time</th>
                  <% } %>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% if (!recentAppointments || recentAppointments.length === 0) { %>
                  <tr>
                    <td colspan="<%= profile.role === 'doctor' || profile.role === 'admin' ? 4 : 4 %>" class="text-center py-4 text-muted">No appointments found.</td>
                  </tr>
                <% } else { %>
                  <% recentAppointments.forEach((record) => { %>
                    <% const patientUser = record.user_id && record.user_id.first_name ? record.user_id : null; %>
                    <tr>
                      <% if (profile.role === "doctor") { %>
                        <td><%= patientUser ? patientUser.first_name + " " + patientUser.last_name : record.full_name || "-" %></td>
                        <td><%= patientUser ? patientUser.email : record.email || "-" %></td>
                        <td><%= record.appointment_date || "-" %></td>
                      <% } else if (profile.role === "admin") { %>
                        <td><%= patientUser ? patientUser.first_name + " " + patientUser.last_name : record.full_name || "-" %></td>
                        <td><%= record.doctor_id && record.doctor_id.name ? record.doctor_id.name : record.doctor_name || "-" %></td>
                        <td><%= record.appointment_date || "-" %></td>
                      <% } else { %>
                        <td><%= record.appointment_date || record.createdAt %></td>
                        <td><%= record.doctor_id && record.doctor_id.name ? record.doctor_id.name : record.doctor_name || "-" %></td>
                        <td><%= record.time_slot || "-" %></td>
                      <% } %>
                      <td><span class="badge text-bg-<%= record.status === 'Accepted' ? 'success' : record.status === 'Rejected' ? 'danger' : 'warning' %>"><%= record.status === 'Accepted' ? 'Approved' : record.status %></span></td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
