<% layout("layouts/boilerplate") %>

<div class="appointment-progress">
  <div class="appointment-progress__ring" data-progress-ring>
    <span class="appointment-progress__value" data-progress-value>0%</span>
  </div>
</div>

<div class="py-4 py-lg-5">
  <div class="mb-4">
    <h1 class="h3 fw-bold mb-2">Book Appointment</h1>
    <p class="text-muted mb-0">Submit a request, let admin approve it, and download the receipt when it is ready.</p>
  </div>

  <% if (message) { %>
    <div class="alert alert-warning"><%= message %></div>
  <% } %>

  <div class="row g-4">
    <div class="col-lg-8">
      <form action="/appointment" method="POST" class="needs-validation" novalidate data-appointment-form>
        <input type="hidden" name="doctor_id" value="<%= formData.doctor_id || '' %>">
        <input type="hidden" name="doctor_name" value="<%= formData.doctor_name || '' %>">

        <div class="card mb-4">
          <div class="card-body p-4">
            <h2 class="h5 mb-3">Patient Details</h2>
            <div class="alert alert-light border small mb-3">
              Your profile is linked automatically, so admin and doctor can see who submitted the request.
            </div>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Full Name</label>
                <input type="text" name="full_name" class="form-control" value="<%= formData.full_name || '' %>" readonly>
                <div class="form-text">Auto-filled from your signed-in profile.</div>
              </div>
              <div class="col-md-4">
                <label class="form-label">Phone Number</label>
                <input type="tel" name="phone" class="form-control" value="<%= formData.phone || '' %>" required placeholder="10-digit mobile number" pattern="[0-9]{10}">
              </div>
              <div class="col-md-4">
                <label class="form-label">Email ID</label>
                <input type="email" name="email" class="form-control" value="<%= formData.email || '' %>" readonly>
                <div class="form-text">Auto-filled from your signed-in profile.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="card mb-4">
          <div class="card-body p-4">
            <h2 class="h5 mb-3">Doctor Selection</h2>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Specialization</label>
                <select name="specialization" class="form-select" required>
                  <option value="">Choose...</option>
                  <% specializationOptions.forEach((option) => { %>
                    <option value="<%= option.value %>" <%= (formData.specialization || '') === option.value ? 'selected' : '' %>><%= option.label %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label">Appointment Date</label>
                <input type="date" name="appointment_date" class="form-control" value="<%= formData.appointment_date || '' %>" required>
              </div>
              <div class="col-md-6">
                <label class="form-label">Doctor Selected</label>
                <input type="text" class="form-control" value="<%= formData.doctor_name || '' %>" readonly placeholder="Select from doctor page">
              </div>
              <div class="col-md-6 d-flex align-items-end">
                <button type="button" class="btn btn-outline-primary w-100" data-browse-doctors>Browse Doctors</button>
              </div>
            </div>

            <% if (selectedDoctor) { %>
              <div class="alert alert-light border mt-4 mb-0">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                  <div>
                    <h3 class="h6 mb-1"><%= selectedDoctor.name %></h3>
                    <div class="text-muted small"><%= specializationOptions.find((item) => item.value === selectedDoctor.specialization)?.label || selectedDoctor.specialization %></div>
                  </div>
                  <span class="badge text-bg-<%= availableSlots.length ? 'success' : 'secondary' %>">
                    <%= availableSlots.length ? 'Available' : 'No slots available' %>
                  </span>
                </div>
                <div class="mt-3 small text-muted">
                  Availability days: <%= (selectedDoctor.availability_days || []).join(", ") %>
                </div>
              </div>
            <% } %>

            <div class="mt-4">
              <label class="form-label">Available Time Slots</label>
              <select name="time_slot" class="form-select" <%= selectedDoctor ? '' : 'disabled' %> required>
                <option value=""><%= selectedDoctor ? 'Choose a time slot' : 'Select a doctor first' %></option>
                <% (availableSlots || []).forEach((slot) => { %>
                  <option value="<%= slot %>" <%= (formData.time_slot || '') === slot ? 'selected' : '' %>><%= slot %></option>
                <% }) %>
              </select>
              <div class="form-text">The page only shows slots that are still free for the selected doctor and date.</div>
            </div>
          </div>
        </div>

        <div class="card mb-4">
          <div class="card-body p-4">
            <h2 class="h5 mb-3">Request Details</h2>
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label">Symptoms / Problem Description</label>
                <textarea name="symptoms" class="form-control" rows="4" required><%= formData.symptoms || '' %></textarea>
              </div>
              <div class="col-12">
                <label class="form-label">Urgency Level</label>
                <select name="urgency_level" class="form-select">
                  <% urgencyOptions.forEach((option) => { %>
                    <option value="<%= option.value %>" <%= (formData.urgency_level || 'medium') === option.value ? 'selected' : '' %>><%= option.label %></option>
                  <% }) %>
                </select>
                <div class="form-text">This helps admin decide whether the request needs urgent review.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="card mb-4">
          <div class="card-body p-4">
            <h2 class="h5 mb-3">Confirmation</h2>
            <div class="row g-3">
              <div class="col-12">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="consent" id="appointmentConsent" <%= formData.consent ? 'checked' : '' %> required>
                  <label class="form-check-label" for="appointmentConsent">
                    I confirm the appointment details are correct and I understand admin approval is required.
                  </label>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2">
          <button type="submit" class="btn btn-primary btn-lg">Submit Appointment</button>
          <a href="/check-status" class="btn btn-outline-secondary btn-lg">Check Status</a>
        </div>
      </form>
    </div>

    <div class="col-lg-4">
        <div class="card position-sticky" style="top: 1rem;">
          <div class="card-body p-4">
            <h2 class="h6 text-uppercase text-muted mb-3">Quick Summary</h2>
            <ul class="list-unstyled mb-0 small text-muted">
              <li class="mb-2">Name and email are auto-filled from the signed-in patient profile.</li>
              <li class="mb-2">Doctor selection is filtered by specialization and date.</li>
              <li class="mb-2">Admin approves the request before it becomes an appointment.</li>
              <li class="mb-0">A PDF receipt is available from the status page after submission.</li>
            </ul>
          </div>
        </div>
      </div>
  </div>
</div>

<script src="/js/appointment.js"></script>
