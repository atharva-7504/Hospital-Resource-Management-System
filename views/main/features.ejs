<% layout("layouts/boilerplate") %>

<div class="py-4">
  <div class="card mb-4">
    <div class="card-body p-4 p-md-5">
      <h1 class="h3 mb-3">Features</h1>
      <p class="mb-0">
        The app keeps the UI simple and uses MongoDB for users, appointments, bed requests, bed admissions, and the doctor roster.
      </p>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-body">
          <h2 class="h5">Public pages</h2>
          <p class="mb-0 text-muted">Login, signup, appointment, status, features, and about pages are easy to reach from the nav.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-body">
          <h2 class="h5">MongoDB storage</h2>
          <p class="mb-0 text-muted">Users go into the users collection, appointments go into appointment_details, doctors can queue bed requests, and admins approve them into bed_admissions.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-body">
          <h2 class="h5">Operations tracking</h2>
          <p class="mb-0 text-muted">Admins can track ward pressure, doctor availability, and request queues from dedicated pages.</p>
        </div>
      </div>
    </div>
  </div>
</div>
